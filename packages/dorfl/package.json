{
	"name": "dorfl",
	"version": "0.9.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/wighawag/dorfl.git",
		"directory": "packages/dorfl"
	},
	"homepage": "https://github.com/wighawag/dorfl#readme",
	"bugs": "https://github.com/wighawag/dorfl/issues",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"bin": {
		"dorfl": "dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"src"
	],
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"commander": "^14.0.1"
	},
	"devDependencies": {
		"@types/node": "^25.2.0",
		"as-soon": "^0.1.5",
		"tsx": "^4.21.0",
		"typescript": "^5.3.3",
		"vitest": "^4.0.18"
	},
	"scripts": {
		"build": "tsc && node scripts/vendor-protocol.mjs && node scripts/vendor-skills.mjs",
		"dev": "as-soon -w src pnpm build",
		"cli": "tsx src/cli.ts",
		"test": "vitest run",
		"test:watch": "vitest"
	}
}
